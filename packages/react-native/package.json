{
  "name": "@auto-topup/react-native",
  "version": "0.2.1",
  "description": "Retailcode SDK — React Native components",
  "license": "MIT",
  "homepage": "https://github.com/FBIS-Tech/auto-topup-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/FBIS-Tech/auto-topup-sdk.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auto-topup/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.1",
    "react-native-safe-area-context": "^5.0.0",
    "tsup": "*",
    "typescript": "*"
  }
}
