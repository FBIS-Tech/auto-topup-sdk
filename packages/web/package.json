{
  "name": "@auto-topup/web",
  "version": "0.3.0",
  "description": "Retailcode SDK — browser widget (Shadow DOM)",
  "license": "MIT",
  "homepage": "https://github.com/FBIS-Tech/auto-topup-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/FBIS-Tech/auto-topup-sdk.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./iife": "./dist/retailcode.iife.global.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auto-topup/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  }
}
