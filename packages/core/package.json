{
  "name": "@auto-topup/core",
  "version": "0.3.0",
  "description": "Retailcode SDK core — shared API client, types, and utilities",
  "license": "MIT",
  "homepage": "https://github.com/FBIS-Tech/auto-topup-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/FBIS-Tech/auto-topup-sdk.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  }
}
